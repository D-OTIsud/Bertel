# Documentation folder (contains its own git repository)
"Documentation Bertel v3.0/"

# Common files to ignore
.DS_Store
Thumbs.db
*.log
*.tmp
*.temp
# scratch deploy/test artifacts (e.g. crm_body.tmp.sql, notes.tmp.md) — *.tmp doesn't catch these
*.tmp.*
# .tmp_-prefixed scratch dirs/scripts (e.g. .tmp_pgapply/, .tmp_harness/, .tmp_sizes.cjs);
# the *.tmp suffix globs above don't catch a .tmp_ prefix. Matches in any directory.
.tmp_*

# generated live-reference dump (2.28 MB; regenerated by tools/db-graph; the doc falls back to seeds without it)
db-graph-out/reference_live.json

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Environment files
.env
.env.*
!.env.example

# Database files
*.db
*.duckdb
*.duckdb.wal
*.sqlite
*.sqlite3

# Backup files
*.bak
*.backup

# Python
__pycache__/
*.py[cod]
.pip-cache/
.pytest_cache/

# Node
node_modules/
.npm-cache/
.playwright-browsers/
.next/
storybook-static/
bertel-tourism-ui/next-env.d.ts
bertel-tourism-ui/tsconfig.tsbuildinfo

# Test artifacts
test_results.txt
playwright-report/
test-results/
docs/schema-workbench/schemaspy-output/

# Git worktrees
.worktrees/

# Brainstorming visual companion scratch (not part of the app)
.superpowers/

# Repo-local tool installs and homes
.tools/
.supabase-home/
.storybook-home/

# AI assistant tooling (not part of the app)
CLAUDE.md
.claude/
.cursor/
claude_brief/
*.mdc
GEMINI.md
AGENTS.md
graphify-out/

# Local-only operational SQL kept out of the open-source repo
Base de donnée DLL et API/lot1_pilot_inserts.sql

# Données sensibles — ne pas committer
# (purgées de l'historique GitHub ; conservées localement uniquement)
Base de donnée DLL et API/Old_data/
Base de donnée DLL et API/Old_data_cleaned/
Base de donnée DLL et API/old_data_supabase_import_20260501/
Base de donnée DLL et API/old_data_enrichment_20260512/

# DB knowledge graph — transient/bulky outputs (db-graph-out/graph.json + *.md ARE committed)
db-graph-out/schema_tbls.json
db-graph-out/catalog_extra.json
db-graph-out/graph.html

# tbls-generated per-table DB docs (16 MB, 678 files — fully regenerable from
# tools/db-graph/.tbls.yml; the committed DB artifacts live in db-graph-out/)
dbdoc/

# Superpowers plan-session working notes (the durable outputs are the committed
# plans + the decision log; these are per-session research scratch). The durable
# plans are non-dotfiles, so ignore every dotfile here: .research/, .taskN-report.md,
# .final-review.diff, .taskN-review.diff, etc.
docs/superpowers/plans/.*

# Root-level scratch / one-off analysis artifacts (Berta import scripts, ad-hoc
# SQL/CSV/JSON dumps). Convention: throwaway working files are prefixed "_" at the
# repo root. The durable outputs are committed under docs/research/ + the migrations.
/_*

