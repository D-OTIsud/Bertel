# Next.js (primary): use NEXT_PUBLIC_* for client-exposed config
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_ENABLE_DEMO_MODE=false
NEXT_PUBLIC_MAP_STYLE_CLASSIC=https://demotiles.maplibre.org/style.json
NEXT_PUBLIC_MAP_STYLE_SATELLITE=https://tiles.openfreemap.org/styles/liberty
NEXT_PUBLIC_MAP_STYLE_TOPO=https://tiles.openfreemap.org/styles/bright

# Vite (legacy dev:vite / build:vite): optional
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_ENABLE_DEMO_MODE=false
VITE_MAP_STYLE_CLASSIC=https://demotiles.maplibre.org/style.json
VITE_MAP_STYLE_SATELLITE=https://tiles.openfreemap.org/styles/liberty
VITE_MAP_STYLE_TOPO=https://tiles.openfreemap.org/styles/bright