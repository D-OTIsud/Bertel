# Required
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY
OPENAI_API_KEY=YOUR_OPENAI_KEY
API_BEARER_TOKEN=CHANGE_ME

# Optional
RAW_IMPORT_BUCKET=raw_imports
APP_ENV=development
LLM_MODEL=gpt-4o-mini
INGEST_SAMPLE_ROWS=5
ETL_CHUNK_SIZE=500
ETL_MAX_ATTEMPTS=3
ETL_RETRY_BACKOFF_SECONDS=2
INGEST_MAX_BYTES=25000000
MIN_CONFIDENCE_THRESHOLD=0.5
MIN_SHEET_CONFIDENCE_THRESHOLD=0.5
VECTOR_DB_URL=

# UI (set automatically in Docker)
API_BASE_URL=http://api:8000


