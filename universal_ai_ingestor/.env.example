SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY
OPENAI_API_KEY=YOUR_OPENAI_KEY
# UI/API bearer token (used for all API authentication)
API_BEARER_TOKEN=CHANGE_ME

# Optional but useful
SUPABASE_DB_URL=
RAW_IMPORT_BUCKET=raw_imports
LLM_MODEL=gpt-4o-mini
INGEST_SAMPLE_ROWS=5
CLEANER_BATCH_SIZE=50
ETL_CHUNK_SIZE=500
ETL_MAX_ATTEMPTS=3
ETL_RETRY_BACKOFF_SECONDS=2
INGEST_MAX_BYTES=25000000
INGEST_LIST_DEFAULT_LIMIT=50
INGEST_LIST_MAX_LIMIT=200
MEDIA_BUCKET=media
MEDIA_DOWNLOAD_TIMEOUT_SECONDS=20
MEDIA_MAX_BYTES=15000000
MEDIA_ALLOWED_DOMAINS=
MEDIA_CONFIDENCE_AUTO=0.9
MEDIA_CONFIDENCE_REVIEW=0.6

# UI helper
# For Docker internal network use http://api:8000
API_BASE_URL=http://api:8000
